    <script>
      // @ts-ignore
      window.dataLayer = window.dataLayer || [];
      function gtag(...args: any[]) {
        // @ts-ignore
        dataLayer.push(arguments);
      }
      gtag('js', new Date());
      gtag('config', 'G-5GQSHYPQM7');

      // Track Core Web Vitals
