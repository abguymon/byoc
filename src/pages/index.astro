    <!-- Structured Data -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Event",
        "name": "BYO Cake Club - Boise Community Event",
        "description": "A community potluck where cake enthusiasts gather to share their homemade creations. Bring your own delicious cake creation and sample amazing cakes from other bakers!",
        "startDate": "2024-10-04T11:00:00-07:00",
        "endDate": "2024-10-04T15:00:00-07:00",
        "eventStatus": "https://schema.org/EventScheduled",
        "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
        "location": {
          "@type": "Place",
          "name": "Camel's Back Park",
          "address": {
            "@type": "PostalAddress",
            "addressLocality": "Boise",
            "addressRegion": "ID",
            "addressCountry": "US"
          }
        },
        "organizer": {
          "@type": "Organization",
          "name": "BYO Cake Club"
        },
        "offers": {
          "@type": "Offer",
          "availability": "https://schema.org/InStock",
          "price": "5",
          "priceCurrency": "USD",
          "description": "$5 per person covers rentals, venue, utensils, and to-go boxes"
        },
        "audience": {
          "@type": "Audience",
          "audienceType": "Cake enthusiasts and bakers"
        }
      }
    </script>

    <script>
      // Declare gtag function for TypeScript
      declare function gtag(...args: any[]): void;

      // Error tracking
      window.addEventListener('error', function (e) {
        if (typeof gtag !== 'undefined') {
          gtag('event', 'exception', {
            description: e.message,
            fatal: false,
          });
        }
      });

      // Handle form submission inline
      const form = document.querySelector('form[name="signup"]');
      const emailInput = document.getElementById(
        'email-input'
      ) as HTMLInputElement;
      const signupButton = document.getElementById(
        'signup-button'
      ) as HTMLButtonElement;
      const successMessage = document.getElementById('success-message');

      if (form && emailInput && signupButton && successMessage) {
        form.addEventListener('submit', async function (e) {
          e.preventDefault();

          const email = emailInput.value;

          if (email && email.includes('@')) {
            // Track form submission
            if (typeof gtag !== 'undefined') {
              gtag('event', 'form_submit', {
                event_category: 'engagement',
                event_label: 'email_signup',
              });
            }

            // Show loading state
            signupButton.textContent = 'SENDING...';
            signupButton.disabled = true;

            try {
              // Send welcome email using Resend
              const response = await fetch('/api/send-welcome-email', {
                method: 'POST',
                headers: {
                  'Content-Type': 'application/json',
                },
                body: JSON.stringify({
                  email: email,
                  event_date: 'October 4th, 2024',
                  event_location: "Camel's Back Park",
                  event_time: '11:00 AM - 1:00 PM',
                  contact_email: 'bringyourowncake@gmail.com',
                  ticket_price: '$5 per person',
                }),
              });

              if (response.ok) {
                // Hide form and show success message
                form.style.display = 'none';
                successMessage.style.display = 'block';
                console.log('Welcome email sent successfully');
              } else {
                throw new Error('Failed to send email');
              }
            } catch (error) {
              console.log('Error sending email:', error);

              // Show error state
              signupButton.textContent = 'ERROR - TRY AGAIN';
              signupButton.classList.add('bg-red-500');

              setTimeout(() => {
                signupButton.textContent = 'SIGN UP';
                signupButton.classList.remove('bg-red-500');
                signupButton.disabled = false;
              }, 3000);
            }
          } else {
            // Show validation error
            signupButton.textContent = 'INVALID EMAIL';
            signupButton.classList.add('bg-red-500');

            setTimeout(() => {
              signupButton.textContent = 'SIGN UP';
              signupButton.classList.remove('bg-red-500');
            }, 2000);
          }
        });
      }

      // Smooth infinite scroll gallery
      function initSmoothGallery() {
        const gallery = document.querySelector('.gallery-scroll');
        if (!gallery) return;

        let position = 0;
        const speed = 0.5; // pixels per frame
        const imageWidth = 192; // w-48 = 192px
        const totalImages = 5; // number of unique images
        const resetPoint = imageWidth * totalImages; // when to reset (960px)

        function smoothScroll() {
          position += speed;

          // Reset position when we've scrolled one full set
          if (position >= resetPoint) {
            position = 0;
          }

          // Apply transform
          gallery.style.transform = `translateX(-${position}px)`;
          requestAnimationFrame(smoothScroll);
        }

        // Start the animation
        smoothScroll();
      }

      // Initialize when page loads
      document.addEventListener('DOMContentLoaded', initSmoothGallery);
    </script>
	</body>
</html>
