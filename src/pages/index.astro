---
// Set the page title and metadata
import { Image } from 'astro:assets';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Bring Your Own Cake Club is coming to Boise and Salt Lake City in Spring 2026! Bring a homemade cake, sample amazing creations from fellow bakers, and celebrate community."
    />
    <meta name="author" content="Bring Your Own Cake Club" />
    <meta
      name="robots"
      content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"
    />
    <meta name="theme-color" content="#E6397F" />
    <meta name="msapplication-TileColor" content="#E6397F" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="BYO Cake Club" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://bringyourowncake.com/" />
    <meta property="og:title" content="BYO Cake Club - Boise & Salt Lake City Spring 2026" />
    <meta
      property="og:description"
      content="Bring Your Own Cake Club is coming to Boise and Salt Lake City in Spring 2026! Bring a homemade cake, sample amazing creations from fellow bakers, and celebrate community."
    />
    <meta
      property="og:image"
      content="https://bringyourowncake.com/og-image.svg"
    />
    <meta property="og:site_name" content="BYO Cake Club" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content="https://bringyourowncake.com/" />
    <meta
      property="twitter:title"
      content="BYO Cake Club - Boise & Salt Lake City Spring 2026"
    />
    <meta
      property="twitter:description"
      content="Bring Your Own Cake Club is coming to Boise and Salt Lake City in Spring 2026! Bring a homemade cake, sample amazing creations from fellow bakers, and celebrate community."
    />
    <meta
      property="twitter:image"
      content="https://bringyourowncake.com/twitter-image.svg"
    />

    <!-- Canonical URL -->
    <link rel="canonical" href="https://bringyourowncake.com/" />

    <title>BYO Cake Club - Boise & Salt Lake City | Coming Spring 2026</title>

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-5GQSHYPQM7"
    ></script>
    <script>
      // @ts-ignore
      window.dataLayer = window.dataLayer || [];
      function gtag(...args: any[]) {
        // @ts-ignore
        dataLayer.push(arguments);
      }
      gtag('js', new Date());
      gtag('config', 'G-5GQSHYPQM7');

      // Track Core Web Vitals
      gtag('event', 'web_vitals', {
        event_category: 'Web Vitals',
        event_label: 'CLS',
        value: Math.round(performance.now()),
      });
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Great+Vibes&family=Inter:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
    <link rel="apple-touch-icon" href="/byocakeclub.png" />

    <style>
      @keyframes marquee {
        from { transform: translateX(0); }
        to   { transform: translateX(-50%); }
      }

      .gallery-track {
        display: flex;
        gap: 1rem;
        width: max-content;
        animation: marquee 20s linear infinite;
      }

      .gallery-track:hover {
        animation-play-state: paused;
      }
    </style>
	</head>
  <body class="bg-byoc-teal min-h-screen">
    <div class="max-w-7xl mx-auto">
      <!-- Header Section -->
      <div class="relative">
        <!-- Small header text -->
        <div class="pt-8 px-6">
          <h1 class="text-byoc-pink text-xl font-sans uppercase tracking-wider">
            BRING YOUR OWN CAKE CLUB
          </h1>
        </div>

        <!-- Main image and logo section -->
        <div
          class="flex items-center justify-center mt-8 sm:mt-12 gap-3 sm:gap-4 lg:gap-8 px-4"
        >
          <!-- Main event image -->
          <div
            class="w-3/5 sm:w-3/5 max-w-2xl h-[200px] sm:h-[400px] lg:h-[500px] relative flex-shrink-0"
          >
            <Image
              src="/cake_head.JPG"
              alt="BYO Cake Club main event photo"
              width={800}
              height={500}
              class="w-full h-full object-cover"
              loading="eager"
              quality={85}
            />
          </div>

          <!-- Logo -->
          <div
            class="w-2/5 sm:w-2/5 max-w-md flex items-center justify-center flex-shrink"
          >
            <Image
              src="/byocakeclub.png"
              alt="BYO Cake CLUB Logo"
              width={300}
              class="w-full h-auto max-w-[120px] sm:max-w-[200px] lg:max-w-md"
              loading="eager"
              quality={90}
            />
          </div>
        </div>
      </div>

      <!-- Next Event & Sign Up Section -->
      <div
        class="px-4 sm:px-8 lg:px-12 pt-16 sm:pt-24 lg:pt-36 pb-16 text-center"
      >
        <p
          class="text-byoc-pink text-base sm:text-lg font-sans uppercase tracking-wider mb-6"
        >
          COMING SPRING 2026
        </p>
        <h2
          class="text-byoc-pink text-3xl sm:text-4xl lg:text-6xl font-serif font-bold mb-12 px-4"
        >
          BOISE &amp; SALT LAKE CITY
        </h2>

        <p
          class="text-byoc-pink text-sm sm:text-base lg:text-lg font-sans uppercase tracking-wider mb-8 px-4"
        >
          SIGN UP TO JOIN THE CLUB AND RECEIVE AN INVITE
        </p>

        <!-- Sign up form -->
        <div id="signup-container" class="max-w-lg mx-auto px-4">
          <form
            id="signup-form"
            class="flex flex-col sm:flex-row gap-4 sm:gap-6"
          >
            <input
              type="email"
              name="email"
              id="email-input"
              placeholder="EMAIL ADDRESS"
              required
              class="flex-1 px-4 sm:px-6 py-3 sm:py-4 border border-gray-300 rounded-none text-sm sm:text-base font-sans placeholder-gray-400 focus:outline-none focus:border-byoc-pink"
            />
            <button
              type="submit"
              id="signup-button"
              class="bg-byoc-pink text-white px-8 sm:px-12 py-3 sm:py-4 text-sm sm:text-base font-sans uppercase tracking-wider hover:bg-opacity-90 transition-colors"
            >
              SIGN UP
            </button>
          </form>

          <!-- Ticket Purchase Section (always visible) -->
          <div id="payment-section" class="bg-white rounded-lg shadow-lg p-6 max-w-md mx-auto mt-8">
            <h2 class="text-byoc-pink text-lg font-sans font-semibold mb-4">
              Ready to Join Us?
            </h2>
            <p class="text-gray-700 text-sm mb-4">
              Purchase your ticket now and secure your spot at the event!
            </p>
            <a
              href={import.meta.env.STRIPE_CHECKOUT_URL || "#"}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-block bg-byoc-pink text-white px-6 py-3 rounded-lg font-sans font-semibold hover:bg-opacity-90 transition-colors text-sm"
            >
              Buy Ticket - $10
            </a>
            <p class="text-gray-500 text-xs mt-3">
              Secure checkout powered by Stripe
            </p>
          </div>

          <!-- Success message (hidden by default) -->
          <div
            id="success-message"
            class="text-center py-8"
            style="display: none;"
          >
            <p class="text-byoc-pink text-lg sm:text-xl font-sans mb-4">
              Thanks for signing up! 🎂
            </p>
            <p class="text-byoc-text-pink text-base font-sans mb-6">
              We'll email you an invite with all the event details.
            </p>
          </div>
        </div>
      </div>

      <!-- Image Gallery Section -->
      <div class="py-12 overflow-hidden">
        <div class="gallery-track">
          <!-- Images (duplicated once for seamless CSS loop) -->
          {[
            { src: "/cake1.JPG", alt: "Pink cake with fruit decoration" },
            { src: "/cake2.JPG", alt: "Tent event setup with desserts" },
            { src: "/cake3.JPG", alt: "Chalkboard sign with cake drawing" },
            { src: "/cake4.JPG", alt: "Dessert table with various baked goods" },
            { src: "/cake5.JPG", alt: "People gathering at the cake event" },
          ].map(({ src, alt }) => (
            <div class="w-48 h-48 flex-shrink-0 overflow-hidden">
              <Image src={src} alt={alt} width={384} height={384} class="w-full h-full object-cover" loading="lazy" quality={90} />
            </div>
          ))}
          {/* Duplicate set for CSS marquee loop — hidden from assistive technology */}
          {[
            { src: "/cake1.JPG" },
            { src: "/cake2.JPG" },
            { src: "/cake3.JPG" },
            { src: "/cake4.JPG" },
            { src: "/cake5.JPG" },
          ].map(({ src }) => (
            <div class="w-48 h-48 flex-shrink-0 overflow-hidden" aria-hidden="true">
              <Image src={src} alt="" width={384} height={384} class="w-full h-full object-cover" loading="lazy" quality={90} />
            </div>
          ))}
        </div>
      </div>

      <!-- Information Sections -->
      <div class="px-6 lg:px-12 py-16 space-y-16">
        <!-- WHO ARE WE? -->
        <div>
          <h2
            class="text-byoc-pink text-lg font-sans uppercase tracking-wider mb-6"
          >
            WHO ARE WE?
          </h2>
          <p
            class="text-byoc-text-pink text-base font-sans leading-relaxed max-w-4xl"
          >
            BYOC is simply a celebration of baked goods. Bring your own cake and
            join our club! Just bring a cake (one per person) and marvel at
            Boise's bakings. There are no rules with your cake (though homemade
            and decorated cakes are encouraged)! Come share your creations and
            meet like-minded cake lovers!
          </p>
        </div>

        <!-- WHAT TO EXPECT -->
        <div>
          <h2
            class="text-byoc-pink text-lg font-sans uppercase tracking-wider mb-6"
          >
            WHAT TO EXPECT
          </h2>
          <p
            class="text-byoc-text-pink text-base font-sans leading-relaxed max-w-4xl"
          >
            Bring your own delicious cake creation and sample amazing cakes from
            other bakers! It's a day filled with sugar, creativity, and
            community.
          </p>
        </div>

        <!-- EVENT DETAILS -->
        <div>
          <h2
            class="text-byoc-pink text-lg font-sans uppercase tracking-wider mb-6"
          >
            EVENT DETAILS
          </h2>
          <p
            class="text-byoc-text-pink text-base font-sans leading-relaxed mb-4 max-w-4xl"
          >
            We're returning to Boise for another celebration of homemade cakes — and this spring we're also launching for the first time in Salt Lake City!
          </p>
          <ul class="text-byoc-text-pink text-base font-sans leading-relaxed mb-4 max-w-4xl space-y-2 list-none">
            <li><span class="text-byoc-pink font-bold">Boise, ID</span> — Camel's Back Park, Spring 2026</li>
            <li><span class="text-byoc-pink font-bold">Salt Lake City, UT</span> — Sugar House Park, Spring 2026 <span class="italic">(brand new!)</span></li>
          </ul>
          <p
            class="text-byoc-text-pink text-base font-sans leading-relaxed max-w-4xl"
          >
            Sign up above to receive the full invite and details once dates are confirmed, or email us at{' '}
            <a href="mailto:bringyourowncake@gmail.com" class="text-byoc-pink font-bold text-lg hover:underline">
              bringyourowncake@gmail.com
            </a>.
          </p>
        </div>

        <!-- WHO IS INVITED -->
        <div>
          <h2
            class="text-byoc-pink text-lg font-sans uppercase tracking-wider mb-6"
          >
            WHO IS INVITED
          </h2>
          <p
            class="text-byoc-text-pink text-base font-sans leading-relaxed max-w-4xl"
          >
            We want any cake lover in Boise to join our event for an opportunity
            to meet new friends and marvel at each others baked goods!
          </p>
          <p
            class="text-byoc-text-pink text-base font-sans leading-relaxed max-w-4xl mt-4"
          >
            All are welcome to bring a cake and enjoy the event—just RSVP
            through the email so we can plan for numbers!
          </p>
        </div>

        <!-- PRICING -->
        <div>
          <h2
            class="text-byoc-pink text-lg font-sans uppercase tracking-wider mb-6"
          >
            PRICING
          </h2>
          <p
            class="text-byoc-text-pink text-base font-sans leading-relaxed max-w-4xl mb-4"
          >
            We want this event to be accessible to anyone interested so the
            ticket price is only <span class="text-byoc-pink font-bold text-lg"
              >$10 per person</span
            >.
          </p>
          <p
            class="text-byoc-text-pink text-base font-sans leading-relaxed max-w-4xl"
          >
            This is just to cover the rentals, venue and the utensils and to-go
            boxes provided.
          </p>
        </div>
      </div>

      <!-- Footer -->
      <footer class="px-12 py-12 text-center">
        <p class="text-byoc-text-pink text-base font-sans">
          Made with love and lots of sugar
        </p>
        <p class="text-byoc-text-pink text-sm mt-3 font-sans">
          © 2026 BYO Cake Club
        </p>
      </footer>
    </div>

    <!-- Structured Data -->
    <script type="application/ld+json">
      [
        {
          "@context": "https://schema.org",
          "@type": "Event",
          "name": "BYO Cake Club - Boise",
          "description": "A community potluck where cake enthusiasts gather to share their homemade creations. Bring your own delicious cake and sample amazing creations from fellow bakers!",
          "startDate": "2026-04-01",
          "eventStatus": "https://schema.org/EventScheduled",
          "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
          "location": {
            "@type": "Place",
            "name": "Camel's Back Park",
            "address": {
              "@type": "PostalAddress",
              "addressLocality": "Boise",
              "addressRegion": "ID",
              "addressCountry": "US"
            }
          },
          "organizer": {
            "@type": "Organization",
            "name": "BYO Cake Club",
            "url": "https://bringyourowncake.com"
          },
          "offers": {
            "@type": "Offer",
            "availability": "https://schema.org/InStock",
            "price": "10",
            "priceCurrency": "USD",
            "url": "https://bringyourowncake.com",
            "description": "$10 per person covers rentals, venue, utensils, and to-go boxes"
          }
        },
        {
          "@context": "https://schema.org",
          "@type": "Event",
          "name": "BYO Cake Club - Salt Lake City",
          "description": "A community potluck where cake enthusiasts gather to share their homemade creations. Bring your own delicious cake and sample amazing creations from fellow bakers!",
          "startDate": "2026-05-01",
          "eventStatus": "https://schema.org/EventScheduled",
          "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
          "location": {
            "@type": "Place",
            "name": "Sugar House Park",
            "address": {
              "@type": "PostalAddress",
              "addressLocality": "Salt Lake City",
              "addressRegion": "UT",
              "addressCountry": "US"
            }
          },
          "organizer": {
            "@type": "Organization",
            "name": "BYO Cake Club",
            "url": "https://bringyourowncake.com"
          },
          "offers": {
            "@type": "Offer",
            "availability": "https://schema.org/InStock",
            "price": "10",
            "priceCurrency": "USD",
            "url": "https://bringyourowncake.com",
            "description": "$10 per person covers rentals, venue, utensils, and to-go boxes"
          }
        }
      ]
    </script>

    <script>
      // Declare gtag function for TypeScript
      declare function gtag(...args: any[]): void;

      // Error tracking
      window.addEventListener('error', function (e) {
        if (typeof gtag !== 'undefined') {
          gtag('event', 'exception', {
            description: e.message,
            fatal: false,
          });
        }
      });

      // Handle form submission inline
      const form = document.getElementById('signup-form');
      const emailInput = document.getElementById(
        'email-input'
      ) as HTMLInputElement;
      const signupButton = document.getElementById(
        'signup-button'
      ) as HTMLButtonElement;
      const successMessage = document.getElementById('success-message');

      if (form && emailInput && signupButton && successMessage) {
        form.addEventListener('submit', async function (e) {
          e.preventDefault();

          const email = emailInput.value;

          if (email && email.includes('@')) {
            // Track form submission
            if (typeof gtag !== 'undefined') {
              gtag('event', 'form_submit', {
                event_category: 'engagement',
                event_label: 'email_signup',
              });
            }

            // Show loading state
            signupButton.textContent = 'SENDING...';
            signupButton.disabled = true;

            try {
              const controller = new AbortController();
              const timeoutId = setTimeout(() => controller.abort(), 10000);

              const response = await fetch('/api/send-welcome-email', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                  email: email,
                  event_date: 'Spring 2026',
                  event_location: 'Boise, ID and Salt Lake City, UT',
                  event_time: 'TBD',
                  contact_email: 'bringyourowncake@gmail.com',
                  ticket_price: '$10 per person',
                }),
                signal: controller.signal,
              });

              clearTimeout(timeoutId);

              if (response.ok) {
                form.style.display = 'none';
                successMessage.style.display = 'block';
              } else {
                // Show error state
                signupButton.textContent = 'ERROR - TRY AGAIN';
                signupButton.classList.add('bg-red-500');

                setTimeout(() => {
                  signupButton.textContent = 'SIGN UP';
                  signupButton.classList.remove('bg-red-500');
                  signupButton.disabled = false;
                }, 3000);
              }

            } catch (error) {

              // Show error state
              signupButton.textContent = 'ERROR - TRY AGAIN';
              signupButton.classList.add('bg-red-500');

              setTimeout(() => {
                signupButton.textContent = 'SIGN UP';
                signupButton.classList.remove('bg-red-500');
                signupButton.disabled = false;
              }, 3000);
            }
          } else {
            // Show validation error
            signupButton.textContent = 'INVALID EMAIL';
            signupButton.classList.add('bg-red-500');

            setTimeout(() => {
              signupButton.textContent = 'SIGN UP';
              signupButton.classList.remove('bg-red-500');
            }, 2000);
          }
        });
      }

    </script>
	</body>
</html>
