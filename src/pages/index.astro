    <script>
      declare function gtag(...args: any[]): void;

      window.addEventListener('error', function (e) {
        if (typeof gtag !== 'undefined') {
          gtag('event', 'exception', { description: e.message, fatal: false });
        }
      });

      // Update buy ticket link when city changes
      const buyLink = document.getElementById('buy-ticket-link') as HTMLAnchorElement;
      const buyHint = document.getElementById('buy-ticket-hint');

      document.querySelectorAll('input[name="city"]').forEach(input => {
        input.addEventListener('change', function () {
          const city = (this as HTMLInputElement).value;
          const url = city === 'boise' ? buyLink.dataset.urlBoise : buyLink.dataset.urlSlc;
          buyLink.href = url || '#';
          buyLink.removeAttribute('aria-disabled');
          buyLink.className = 'inline-block w-full py-4 text-center rounded-lg font-label font-medium text-sm uppercase tracking-widest bg-primary text-on-primary hover:-translate-y-0.5 transition-all cursor-pointer shadow-sm';
          if (buyHint) buyHint.style.display = 'none';
        });
      });

      // Handle email signup
      const form = document.getElementById('signup-form') as HTMLFormElement;
      const emailInput = document.getElementById('email-input') as HTMLInputElement;
      const signupButton = document.getElementById('signup-button') as HTMLButtonElement;
      const successMessage = document.getElementById('success-message');

      if (form && emailInput && signupButton && successMessage) {
        form.addEventListener('submit', async function (e) {
          e.preventDefault();

          const email = emailInput.value;
          const city = (form.closest('section')?.querySelector('input[name="city"]:checked') as HTMLInputElement | null)?.value
            ?? (document.querySelector('input[name="city"]:checked') as HTMLInputElement | null)?.value;

          if (!city) {
            signupButton.textContent = 'SELECT A CITY FIRST';
            signupButton.classList.add('bg-red-600');
            setTimeout(() => {
              signupButton.textContent = 'Sign Up for Invite';
              signupButton.classList.remove('bg-red-600');
            }, 2500);
            return;
          }

          if (!email || !email.includes('@')) {
            signupButton.textContent = 'INVALID EMAIL';
            signupButton.classList.add('bg-red-600');
            setTimeout(() => {
              signupButton.textContent = 'Sign Up for Invite';
              signupButton.classList.remove('bg-red-600');
            }, 2500);
            return;
          }

          if (typeof gtag !== 'undefined') {
            gtag('event', 'form_submit', {
              event_category: 'engagement',
              event_label: 'email_signup',
              event_city: city,
            });
          }

          signupButton.textContent = 'SENDING...';
          signupButton.disabled = true;

          try {
            const controller = new AbortController();
            const timeoutId = setTimeout(() => controller.abort(), 10000);

            const response = await fetch('/api/send-welcome-email', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                email,
                city,
                contact_email: 'bringyourowncake@gmail.com',
                ticket_price: '$10 per person',
              }),
              signal: controller.signal,
            });

            clearTimeout(timeoutId);

            if (response.ok) {
              form.style.display = 'none';
              successMessage.classList.remove('hidden');
            } else {
              signupButton.textContent = 'ERROR — TRY AGAIN';
              signupButton.classList.add('bg-red-600');
              setTimeout(() => {
                signupButton.textContent = 'Sign Up for Invite';
                signupButton.classList.remove('bg-red-600');
                signupButton.disabled = false;
              }, 3000);
            }
          } catch {
            signupButton.textContent = 'ERROR — TRY AGAIN';
            signupButton.classList.add('bg-red-600');
            setTimeout(() => {
              signupButton.textContent = 'Sign Up for Invite';
              signupButton.classList.remove('bg-red-600');
              signupButton.disabled = false;
            }, 3000);
          }
        });
      }
    </script>
