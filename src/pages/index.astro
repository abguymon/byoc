    <script>
      declare function gtag(...args: any[]): void;

      window.addEventListener('error', function (e) {
        if (typeof gtag !== 'undefined') {
          gtag('event', 'exception', { description: e.message, fatal: false });
        }
      });

      // Handle unified club signup
      const signupForm = document.getElementById('signup-form') as HTMLFormElement | null;
      const signupBtn = document.getElementById('signup-btn') as HTMLButtonElement | null;
      const signupSuccess = document.getElementById('signup-success') as HTMLElement | null;

      signupForm?.addEventListener('submit', async function (e) {
        e.preventDefault();

        const email = (signupForm.querySelector('input[type="email"]') as HTMLInputElement).value;

        if (typeof gtag !== 'undefined') {
          gtag('event', 'form_submit', {
            event_category: 'engagement',
            event_label: 'email_signup',
          });
        }

        signupBtn!.textContent = 'SENDING...';
        signupBtn!.disabled = true;

        try {
          const controller = new AbortController();
          const timeoutId = setTimeout(() => controller.abort(), 10000);

          const response = await fetch('/api/send-welcome-email', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email }),
            signal: controller.signal,
          });

          clearTimeout(timeoutId);

          if (response.ok) {
            signupForm.classList.add('hidden');
            signupSuccess?.classList.remove('hidden');
          } else {
            signupBtn!.textContent = 'ERROR — TRY AGAIN';
            signupBtn!.classList.add('bg-red-600');
            setTimeout(() => {
              signupBtn!.textContent = 'Join the Club';
              signupBtn!.classList.remove('bg-red-600');
              signupBtn!.disabled = false;
            }, 3000);
          }
        } catch {
          signupBtn!.textContent = 'ERROR — TRY AGAIN';
          signupBtn!.classList.add('bg-red-600');
          setTimeout(() => {
            signupBtn!.textContent = 'Join the Club';
            signupBtn!.classList.remove('bg-red-600');
            signupBtn!.disabled = false;
          }, 3000);
        }
      });
    </script>
