---
// Set the page title and metadata
---

<html lang='en'>
  <head>
    <meta charset='utf-8' />
    <link rel='icon' type='image/svg+xml' href='/favicon.svg' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <meta
      name='description'
      content='Join us for Bring Your Own Cake - A delicious picnic event in Boise, Idaho! Bring your own cake creation and sample amazing cakes from other bakers. September 20th, 2025.'
    />
    <meta name='keywords' content='cake event, picnic, Boise Idaho, cake potluck, baking, community event, homemade cake, cake lovers' />
    <meta name='author' content='Bring Your Own Cake Event' />
    <meta name='robots' content='index, follow' />
    <meta name='language' content='English' />
    <meta name='revisit-after' content='7 days' />
    
    <!-- Open Graph / Facebook -->
    <meta property='og:type' content='website' />
    <meta property='og:url' content='https://bringyourowncake.com/' />
    <meta property='og:title' content='Bring Your Own Cake - Boise Picnic Event' />
    <meta property='og:description' content='Join us for Bring Your Own Cake - A delicious picnic event in Boise, Idaho! Bring your own cake creation and sample amazing cakes from other bakers.' />
    <meta property='og:image' content='https://bringyourowncake.com/og-image.jpg' />
    <meta property='og:site_name' content='Bring Your Own Cake' />
    <meta property='og:locale' content='en_US' />
    
    <!-- Twitter -->
    <meta property='twitter:card' content='summary_large_image' />
    <meta property='twitter:url' content='https://bringyourowncake.com/' />
    <meta property='twitter:title' content='Bring Your Own Cake - Boise Picnic Event' />
    <meta property='twitter:description' content='Join us for Bring Your Own Cake - A delicious picnic event in Boise, Idaho! Bring your own cake creation and sample amazing cakes from other bakers.' />
    <meta property='twitter:image' content='https://bringyourowncake.com/twitter-image.jpg' />
    
    <!-- Canonical URL -->
    <link rel='canonical' href='https://bringyourowncake.com/' />
    
    <title>Bring Your Own Cake - Boise Picnic Event | September 20th, 2025</title>
    
    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-5GQSHYPQM7"></script>
    <script>
      // @ts-ignore
      window.dataLayer = window.dataLayer || [];
      function gtag(...args: any[]) {
        // @ts-ignore
        dataLayer.push(arguments);
      }
      gtag('js', new Date());
      gtag('config', 'GA_MEASUREMENT_ID');
    </script>
    
    <link
      href='https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Inter:wght@300;400;500;600&display=swap'
      rel='stylesheet'
    />
  </head>
  <body class='bg-anthro-cream min-h-screen'>
    <div class='container mx-auto px-6 py-12 max-w-6xl'>
      <!-- Header -->
      <header class='text-center mb-16'>
        <h1
          class='text-6xl md:text-8xl font-light text-anthro-soft-black mb-6 font-elegant tracking-wide'
        >
          B Y O C
        </h1>
        <p class='text-2xl md:text-3xl text-anthro-warm-gray font-light font-body'>
          Bring Your Own Cake - Cake Potluck in Boise, Idaho
        </p>
      </header>

      <!-- Countdown Timer -->
      <div
        class='bg-white/90 backdrop-blur-sm rounded-none p-12 mb-12 shadow-sm border border-anthro-sage/20'
      >
        <h2
          class='text-3xl font-medium text-center text-anthro-soft-black mb-8 font-elegant tracking-wide'
        >
          Event Countdown
        </h2>
        <div id='countdown' class='text-center'>
          <div
            class='text-5xl md:text-6xl font-light text-anthro-moss mb-4 font-elegant leading-relaxed'
          >
            <span id='days' class='font-medium'>--</span> days <span
              id='hours'
              class='font-medium'>--</span
            >:<span id='minutes' class='font-medium'>--</span>:<span
              id='seconds'
              class='font-medium'>--</span
            >
          </div>
        </div>
        <p class='text-center text-lg text-anthro-warm-gray mt-6 font-body'>
          Until September 20th, 2025
        </p>
      </div>

      <!-- Event Description -->
      <div
        class='bg-white/90 backdrop-blur-sm rounded-none p-12 mb-12 shadow-sm border border-anthro-dusty-rose/20'
      >
        <h2
          class='text-3xl font-medium text-center text-anthro-soft-black mb-8 font-elegant tracking-wide'
        >
          What's This All About?
        </h2>
        <div class='text-center space-y-6'>
          <p
            class='text-lg text-anthro-soft-black leading-relaxed font-body max-w-3xl mx-auto'
          >
            BYOC is simply a celebration of baked goods. Bring your own cake and
            join our community potluck! Just bring a cake (one per person) and
            marvel at Boise's bakings there are no rules with your cake (though
            homemade and decorated cakes are encouraged!) Come share your
            creations and meet like-minded cake lovers!
          </p>
          <p
            class='text-lg text-anthro-soft-black leading-relaxed font-body max-w-3xl mx-auto'
          >
            <span class='font-medium text-anthro-moss'>What to expect:</span> Bring
            your own delicious cake creation and sample amazing cakes from other
            bakers! It's a day filled with sugar, creativity, and community.
          </p>
          <div
            class='text-lg text-anthro-soft-black leading-relaxed font-body max-w-2xl mx-auto space-y-2'
          >
            <p>
              <span class='font-medium text-anthro-moss'>Location:</span> TBA
            </p>
            <p>
              <span class='font-medium text-anthro-moss'>Date:</span> September 20th,
              2025
            </p>
            <p>
              <span class='font-medium text-anthro-moss'>Time:</span> 11:00 AM
            </p>
          </div>
        </div>
      </div>

      <!-- Buy Tickets Button -->
      <div class='text-center mb-12'>
        <button
          id='ticketBtn'
          class='bg-anthro-moss hover:bg-anthro-sage text-white text-xl font-medium py-4 px-16 rounded-none shadow-sm transform hover:scale-105 transition-all duration-300 border border-anthro-moss hover:border-anthro-sage font-body tracking-wide'
        >
          Buy Tickets Now
        </button>
        <p class='text-anthro-warm-gray mt-6 text-base font-body'>
          Click the button above to secure your spot
        </p>
      </div>

      <!-- Social Media Links -->
      <div
        class='bg-white/90 backdrop-blur-sm rounded-none p-12 shadow-sm border border-anthro-lavender/20'
      >
        <h2
          class='text-3xl font-medium text-center text-anthro-soft-black mb-8 font-elegant tracking-wide'
        >
          Follow Us & Share
        </h2>
        <div class='grid grid-cols-3 gap-6 max-w-2xl mx-auto'>
          <a
            href='#'
            class='bg-anthro-sage hover:bg-anthro-moss text-white text-center py-4 px-6 rounded-none shadow-sm font-medium transition-colors duration-300 transform hover:scale-105 font-body tracking-wide'
          >
            Facebook
          </a>
          <a
            href='#'
            class='bg-anthro-dusty-rose hover:bg-anthro-peach text-white text-center py-4 px-6 rounded-none shadow-sm font-medium transition-colors duration-300 transform hover:scale-105 font-body tracking-wide'
          >
            Instagram
          </a>

          <a
            href='#'
            class='bg-anthro-peach hover:bg-anthro-dusty-rose text-white text-center py-4 px-6 rounded-none shadow-sm font-medium transition-colors duration-300 transform hover:scale-105 font-body tracking-wide'
          >
            TikTok
          </a>
        </div>
      </div>

      <!-- Footer -->
      <footer class='text-center mt-16 text-anthro-warm-gray'>
        <p class='text-lg font-body'>Made with love and lots of sugar</p>
        <p class='text-sm mt-3 font-body'>© 2025 Bring Your Own Cake Event</p>
      </footer>
    </div>

    <!-- Structured Data -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Event",
      "name": "Bring Your Own Cake - Boise Picnic Event",
      "description": "A ticketed event where cake enthusiasts gather to share their homemade creations. Bring your own delicious cake creation and sample amazing cakes from other bakers!",
      "startDate": "2025-09-20T14:00:00-07:00",
      "endDate": "2025-09-20T18:00:00-07:00",
      "eventStatus": "https://schema.org/EventScheduled",
      "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
      "location": {
        "@type": "Place",
        "name": "Boise, Idaho",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Boise",
          "addressRegion": "ID",
          "addressCountry": "US"
        }
      },
      "organizer": {
        "@type": "Organization",
        "name": "Bring Your Own Cake Event"
      },
      "offers": {
        "@type": "Offer",
        "availability": "https://schema.org/InStock",
        "price": "0",
        "priceCurrency": "USD",
        "description": "Free event - bring your own cake"
      },
      "audience": {
        "@type": "Audience",
        "audienceType": "Cake enthusiasts and bakers"
      }
    }
    </script>

    <script>
      // Declare gtag function for TypeScript
      declare function gtag(...args: any[]): void;
      
      // Countdown Timer
      function updateCountdown() {
        const eventDate = new Date('September 20, 2025 14:00:00').getTime();
        const now = new Date().getTime();
        const distance = eventDate - now;

        const days = Math.floor(distance / (1000 * 60 * 60 * 24));
        const hours = Math.floor(
          (distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60)
        );
        const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
        const seconds = Math.floor((distance % (1000 * 60)) / 1000);

        const daysEl = document.getElementById('days');
        const hoursEl = document.getElementById('hours');
        const minutesEl = document.getElementById('minutes');
        const secondsEl = document.getElementById('seconds');

        if (daysEl) daysEl.textContent = days.toString();
        if (hoursEl) hoursEl.textContent = hours.toString().padStart(2, '0');
        if (minutesEl)
          minutesEl.textContent = minutes.toString().padStart(2, '0');
        if (secondsEl)
          secondsEl.textContent = seconds.toString().padStart(2, '0');

        if (distance < 0) {
          clearInterval(countdownInterval);
          const countdownEl = document.getElementById('countdown');
          if (countdownEl) {
            countdownEl.innerHTML =
              '<div class="text-5xl md:text-6xl font-light text-anthro-moss font-elegant leading-relaxed">Event is here!</div>';
          }
        }
      }

      // Update countdown every second
      updateCountdown();
      const countdownInterval = setInterval(updateCountdown, 1000);

      // Ticket Button Click Handler
      const ticketBtn = document.getElementById('ticketBtn');
      if (ticketBtn) {
        ticketBtn.addEventListener('click', function () {
          const btn = this as HTMLButtonElement;
          btn.innerHTML = 'Coming Soon';
          btn.classList.add('bg-anthro-warm-gray');
          btn.disabled = true;

          // Track ticket button click
          gtag('event', 'ticket_button_click', {
            event_category: 'engagement',
            event_label: 'ticket_button'
          });

          setTimeout(() => {
            btn.innerHTML = 'Buy Tickets Now';
            btn.classList.remove('bg-anthro-warm-gray');
            btn.disabled = false;
          }, 2000);
        });
      }
    </script>
  </body>
</html>
