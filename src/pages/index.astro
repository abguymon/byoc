---
import { Image } from 'astro:assets';
export const prerender = true;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Bring Your Own Cake Club is coming to Boise and Salt Lake City in Spring 2026! Bring a homemade cake, sample amazing creations from fellow bakers, and celebrate community."
    />
    <meta name="author" content="Bring Your Own Cake Club" />
    <meta
      name="robots"
      content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"
    />
    <meta name="theme-color" content="#52634c" />
    <meta name="msapplication-TileColor" content="#52634c" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="BYO Cake Club" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://bringyourowncake.com/" />
    <meta property="og:title" content="BYO Cake Club - Boise & Salt Lake City Spring 2026" />
    <meta
      property="og:description"
      content="Bring Your Own Cake Club is coming to Boise and Salt Lake City in Spring 2026! Bring a homemade cake, sample amazing creations from fellow bakers, and celebrate community."
    />
    <meta property="og:image" content="https://bringyourowncake.com/og-image.svg" />
    <meta property="og:site_name" content="BYO Cake Club" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content="https://bringyourowncake.com/" />
    <meta property="twitter:title" content="BYO Cake Club - Boise & Salt Lake City Spring 2026" />
    <meta
      property="twitter:description"
      content="Bring Your Own Cake Club is coming to Boise and Salt Lake City in Spring 2026! Bring a homemade cake, sample amazing creations from fellow bakers, and celebrate community."
    />
    <meta property="twitter:image" content="https://bringyourowncake.com/twitter-image.svg" />

    <link rel="canonical" href="https://bringyourowncake.com/" />
    <title>BYO Cake Club - Boise & Salt Lake City | Coming Spring 2026</title>

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-5GQSHYPQM7"></script>
    <script>
      // @ts-ignore
      window.dataLayer = window.dataLayer || [];
      function gtag(...args: any[]) {
        // @ts-ignore
        dataLayer.push(arguments);
      }
      gtag('js', new Date());
      gtag('config', 'G-5GQSHYPQM7');
    </script>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Serif:ital,wght@0,400;0,700;1,400;1,700&family=Work+Sans:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
      rel="stylesheet"
    />
    <link rel="apple-touch-icon" href="/byocakeclub.png" />

    <style>
      .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
      }

      /* Scrapbook photo frame effect */
      .scrapbook-frame {
        position: relative;
      }
      .scrapbook-frame::after {
        content: '';
        position: absolute;
        top: 8px;
        left: 8px;
        right: -8px;
        bottom: -8px;
        border: 1px solid #c4c8be;
        z-index: -1;
        border-radius: 0.5rem;
      }

      /* Subtle linen texture overlay */
      .linen-texture {
        background-image: radial-gradient(#c4c8be 0.5px, transparent 0.5px);
        background-size: 10px 10px;
        opacity: 0.1;
      }

      /* Botanical SVG divider */
      .botanical-divider {
        height: 60px;
        background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 20' preserveAspectRatio='none'><path d='M0 10 Q 25 0, 50 10 T 100 10' fill='none' stroke='%2352634c' stroke-width='0.5' opacity='0.3'/></svg>");
      }

      /* Gallery marquee */
      @keyframes marquee {
        from { transform: translateX(0); }
        to   { transform: translateX(-50%); }
      }
      .gallery-track {
        display: flex;
        gap: 1rem;
        width: max-content;
        animation: marquee 20s linear infinite;
      }
      .gallery-track:hover {
        animation-play-state: paused;
      }
    </style>
  </head>

  <body class="bg-background text-on-background font-body selection:bg-secondary-fixed selection:text-on-secondary-fixed">

    <!-- Navigation -->
    <nav class="bg-[#fef9ed]/80 backdrop-blur-xl sticky top-0 z-50 transition-all duration-500">
      <div class="flex justify-between items-center w-full px-6 sm:px-8 py-4 max-w-7xl mx-auto">
        <a href="/" class="text-xl sm:text-2xl font-headline italic text-primary">
          BRING YOUR OWN CAKE CLUB
        </a>
        <div class="hidden md:flex items-center space-x-8">
          <a href="#about" class="text-on-surface-variant font-label uppercase tracking-widest text-xs hover:text-secondary transition-colors duration-300">About</a>
          <a href="#gallery" class="text-on-surface-variant font-label uppercase tracking-widest text-xs hover:text-secondary transition-colors duration-300">Gallery</a>
          <a href="#faq" class="text-on-surface-variant font-label uppercase tracking-widest text-xs hover:text-secondary transition-colors duration-300">FAQ</a>
        </div>
        <a
          href="#signup"
          class="bg-primary text-on-primary px-5 py-2 rounded-lg font-label text-sm font-medium hover:bg-primary-container hover:text-on-primary-container transition-all duration-300"
        >
          Join the Club
        </a>
      </div>
    </nav>

    <main>

      <!-- Hero Section -->
      <section class="relative min-h-[85vh] flex items-center overflow-hidden bg-surface">
        <div class="absolute inset-0 linen-texture pointer-events-none"></div>
        <div class="max-w-7xl mx-auto px-6 sm:px-8 py-16 grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center w-full">

          <!-- Left: Text -->
          <div class="z-10 order-2 lg:order-1">
            <span class="inline-block px-3 py-1 bg-secondary-container text-secondary font-label text-xs tracking-widest uppercase rounded-sm mb-6">
              Coming Spring 2026 · Boise &amp; Salt Lake City
            </span>
            <h1 class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-headline text-on-background leading-tight mb-8">
              A Slice of<br /><span class="italic text-primary">Community.</span>
            </h1>
            <p class="text-lg text-on-surface-variant max-w-md mb-10 leading-relaxed font-light">
              Gathering cake lovers across the Treasure Valley and Sugar House for a curated afternoon of sugar, stories, and shared tables.
            </p>
            <div class="flex flex-col sm:flex-row gap-4">
              <a
                href="#signup"
                class="bg-primary text-on-primary px-8 py-4 rounded-lg font-label font-medium shadow-sm hover:-translate-y-0.5 transition-all duration-300 text-center"
              >
                Purchase Your Ticket
              </a>
              <a
                href="#about"
                class="border border-outline-variant text-secondary px-8 py-4 rounded-lg font-label font-medium hover:bg-secondary-container/30 transition-all duration-300 text-center"
              >
                Learn More
              </a>
            </div>
          </div>

          <!-- Right: Hero Image -->
          <div class="relative order-1 lg:order-2 flex justify-center">
            <div class="scrapbook-frame w-full max-w-md aspect-[4/5] overflow-hidden rounded-xl">
              <Image
                src="/cake_head.JPG"
                alt="BYO Cake Club main event photo"
                width={600}
                height={750}
                class="w-full h-full object-cover"
                loading="eager"
                quality={85}
              />
            </div>
            <div class="absolute -bottom-4 -left-4 bg-surface-container-highest p-4 rounded-full border border-outline-variant/20 shadow-xl hidden md:flex items-center justify-center">
              <span class="material-symbols-outlined text-primary text-4xl">cake</span>
            </div>
          </div>
        </div>
      </section>

      <!-- Event Details Section -->
      <section class="bg-surface-container-low py-24">
        <div class="max-w-7xl mx-auto px-6 sm:px-8">
          <div class="text-center mb-16">
            <h2 class="text-4xl font-headline text-on-background mb-4">The Details</h2>
            <div class="w-16 h-px bg-secondary mx-auto"></div>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
            <div class="text-center group">
              <div class="w-16 h-16 bg-primary-fixed-dim rounded-full flex items-center justify-center mx-auto mb-6 group-hover:bg-primary-container transition-colors duration-500">
                <span class="material-symbols-outlined text-on-primary-fixed text-2xl">calendar_month</span>
              </div>
              <h3 class="font-headline text-xl mb-2 text-on-background">When</h3>
              <p class="text-on-surface-variant">Spring 2026<br />Date confirmed via email invite</p>
            </div>
            <div class="text-center group">
              <div class="w-16 h-16 bg-primary-fixed-dim rounded-full flex items-center justify-center mx-auto mb-6 group-hover:bg-primary-container transition-colors duration-500">
                <span class="material-symbols-outlined text-on-primary-fixed text-2xl">location_on</span>
              </div>
              <h3 class="font-headline text-xl mb-2 text-on-background">Where</h3>
              <p class="text-on-surface-variant">
                <strong class="text-on-surface">Boise, ID</strong> — Camel's Back Park<br />
                <strong class="text-on-surface">Salt Lake City, UT</strong> — Sugar House Park
              </p>
            </div>
            <div class="text-center group">
              <div class="w-16 h-16 bg-primary-fixed-dim rounded-full flex items-center justify-center mx-auto mb-6 group-hover:bg-primary-container transition-colors duration-500">
                <span class="material-symbols-outlined text-on-primary-fixed text-2xl">local_activity</span>
              </div>
              <h3 class="font-headline text-xl mb-2 text-on-background">What</h3>
              <p class="text-on-surface-variant">A community<br />cake potluck</p>
            </div>
          </div>
        </div>
      </section>

      <!-- Gallery Section -->
      <section id="gallery" class="py-12 overflow-hidden bg-surface">
        <div class="max-w-7xl mx-auto px-6 sm:px-8 mb-8 text-center">
          <span class="text-primary font-label uppercase tracking-widest text-sm font-semibold">Our Community</span>
        </div>
        <div class="gallery-track">
          {[
            { src: "/cake1.JPG", alt: "Pink cake with fruit decoration" },
            { src: "/cake2.JPG", alt: "Tent event setup with desserts" },
            { src: "/cake3.JPG", alt: "Chalkboard sign with cake drawing" },
            { src: "/cake4.JPG", alt: "Dessert table with various baked goods" },
            { src: "/cake5.JPG", alt: "People gathering at the cake event" },
          ].map(({ src, alt }) => (
            <div class="w-56 h-56 flex-shrink-0 overflow-hidden rounded-xl">
              <Image src={src} alt={alt} width={448} height={448} class="w-full h-full object-cover" loading="lazy" quality={90} />
            </div>
          ))}
          {[
            { src: "/cake1.JPG" },
            { src: "/cake2.JPG" },
            { src: "/cake3.JPG" },
            { src: "/cake4.JPG" },
            { src: "/cake5.JPG" },
          ].map(({ src }) => (
            <div class="w-56 h-56 flex-shrink-0 overflow-hidden rounded-xl" aria-hidden="true">
              <Image src={src} alt="" width={448} height={448} class="w-full h-full object-cover" loading="lazy" quality={90} />
            </div>
          ))}
        </div>
      </section>

      <!-- About / Who Are We -->
      <section id="about" class="py-24 bg-surface">
        <div class="max-w-7xl mx-auto px-6 sm:px-8">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
            <!-- Text -->
            <div class="space-y-6">
              <span class="inline-block px-4 py-1 bg-secondary-container text-secondary text-xs font-label uppercase tracking-widest rounded-sm">
                Our Story
              </span>
              <h2 class="font-headline text-5xl md:text-6xl text-on-background leading-tight">Who Are We?</h2>
              <p class="text-lg text-on-surface-variant font-body leading-relaxed">
                BYOC is simply a celebration of baked goods. Bring your own cake and join our club! Just bring a cake (one per person) and marvel at the community's baking. There are no rules with your cake—though homemade and decorated cakes are encouraged. Come share your creations and meet like-minded cake lovers!
              </p>
              <p class="text-lg text-on-surface-variant font-body leading-relaxed">
                We're returning to Boise for another celebration of homemade cakes — and this spring we're also launching for the very first time in Salt Lake City!
              </p>
              <div class="flex items-center gap-4 text-primary font-headline italic text-xl pt-2">
                <span>Boise &amp; Salt Lake City, Spring 2026</span>
              </div>
            </div>

            <!-- Scrapbook photos -->
            <div class="relative h-[480px]">
              <div class="absolute top-0 right-0 w-4/5 h-4/5 z-10 p-2 bg-surface-container shadow-sm rotate-2 overflow-hidden border border-outline-variant/20 rounded-xl">
                <Image
                  src="/cake2.JPG"
                  alt="Community gathering at BYO Cake Club"
                  width={500}
                  height={400}
                  class="w-full h-full object-cover rounded-lg"
                  loading="lazy"
                  quality={85}
                />
              </div>
              <div class="absolute bottom-4 left-0 w-3/5 h-3/5 z-20 p-2 bg-white shadow-md -rotate-2 overflow-hidden border border-outline-variant/20 rounded-xl">
                <Image
                  src="/cake4.JPG"
                  alt="Dessert table at BYO Cake Club"
                  width={400}
                  height={300}
                  class="w-full h-full object-cover rounded-lg"
                  loading="lazy"
                  quality={85}
                />
              </div>
            </div>
          </div>
        </div>
      </section>

      <div class="botanical-divider max-w-4xl mx-auto my-4 opacity-40"></div>

      <!-- Who Is Invited + Ticket -->
      <section class="py-24 bg-surface">
        <div class="max-w-7xl mx-auto px-6 sm:px-8">
          <!-- Header -->
          <div class="text-center mb-16 max-w-4xl mx-auto space-y-4">
            <span class="text-primary font-label uppercase tracking-widest text-sm font-semibold block">All Are Welcome</span>
            <h2 class="text-4xl md:text-6xl font-headline text-on-background leading-tight">Who Is Invited?</h2>
            <div class="w-16 h-0.5 bg-secondary mx-auto"></div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-start bg-surface-container-low rounded-3xl p-8 md:p-16 relative overflow-hidden">
            <!-- Left: description + features -->
            <div class="space-y-6">
              <p class="text-on-surface-variant leading-relaxed">
                We want any cake lover to join our event for an opportunity to meet new friends and marvel at each other's baked goods! All are welcome — whether you're a seasoned baker or it's your first time in the kitchen.
              </p>
              <ul class="space-y-4 pt-4">
                <li class="flex items-center gap-3">
                  <span class="material-symbols-outlined text-primary">local_florist</span>
                  <span class="font-label text-sm uppercase tracking-wide text-on-surface">Amateur &amp; Professional Bakers</span>
                </li>
                <li class="flex items-center gap-3">
                  <span class="material-symbols-outlined text-primary">groups</span>
                  <span class="font-label text-sm uppercase tracking-wide text-on-surface">All Ages Welcome</span>
                </li>
                <li class="flex items-center gap-3">
                  <span class="material-symbols-outlined text-primary">favorite</span>
                  <span class="font-label text-sm uppercase tracking-wide text-on-surface">Community Seekers &amp; Creative Souls</span>
                </li>
              </ul>
            </div>

            <!-- Right: ticket card -->
            <div class="bg-surface p-8 rounded-xl border-b-4 border-secondary/20 shadow-sm flex flex-col justify-center">
              <div class="text-secondary font-headline italic text-2xl mb-2">A Token of Intent</div>
              <div class="text-5xl font-headline text-primary mb-6">$10 Ticket</div>
              <p class="text-sm text-on-surface-variant font-body leading-relaxed mb-8">
                Just $10 per person covers the rentals, venue, utensils, and to-go boxes. We want this event to be accessible to anyone who loves cake.
              </p>
              <a
                href="#signup"
                class="block w-full py-4 text-center border border-outline-variant text-secondary font-label uppercase tracking-widest hover:bg-secondary-container transition-colors duration-300 rounded-lg text-sm"
              >
                Reserve Your Seat
              </a>
            </div>

            <!-- Linen texture overlay -->
            <div class="absolute inset-0 linen-texture pointer-events-none opacity-10 rounded-3xl"></div>
          </div>

          <!-- Photo pair -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-12 mt-16">
            <div class="space-y-4">
              <div class="scrapbook-frame rounded-xl overflow-hidden aspect-[16/10]">
                <Image
                  src="/cake3.JPG"
                  alt="Chalkboard sign at BYO Cake Club"
                  width={600}
                  height={375}
                  class="w-full h-full object-cover"
                  loading="lazy"
                  quality={85}
                />
              </div>
              <div class="flex items-center justify-center space-x-3 bg-secondary-container/30 py-3 rounded-xl">
                <span class="material-symbols-outlined text-secondary text-2xl">volunteer_activism</span>
                <p class="font-headline text-lg text-secondary">Shared Tables</p>
              </div>
            </div>
            <div class="space-y-4">
              <div class="scrapbook-frame rounded-xl overflow-hidden aspect-[16/10]">
                <Image
                  src="/cake5.JPG"
                  alt="People gathering at BYO Cake Club"
                  width={600}
                  height={375}
                  class="w-full h-full object-cover"
                  loading="lazy"
                  quality={85}
                />
              </div>
              <div class="flex items-center justify-center space-x-3 bg-primary-fixed py-3 rounded-xl">
                <span class="material-symbols-outlined text-primary text-2xl">group</span>
                <p class="font-headline text-lg text-on-primary-fixed-variant">All Ages Welcome</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- FAQ Section -->
      <section id="faq" class="bg-surface-container-low py-24">
        <div class="max-w-4xl mx-auto px-6 sm:px-8">
          <div class="text-center mb-16">
            <h2 class="font-headline text-4xl text-on-background mb-4">Common Curiosities</h2>
            <div class="w-24 h-1 bg-secondary/30 mx-auto rounded-full"></div>
          </div>
          <div class="space-y-12">
            <div class="group flex items-start gap-6">
              <span class="font-headline text-3xl text-secondary/40 group-hover:text-secondary transition-colors italic flex-shrink-0">01</span>
              <div>
                <h3 class="font-headline text-xl text-on-background mb-3">Do I actually have to bake a whole cake?</h3>
                <p class="text-on-surface-variant leading-relaxed font-body">While we encourage a full cake, anything baked counts! Tarts, cookies, or a savory bread are welcome. The goal is to bring something that represents you. Homemade and decorated cakes are especially encouraged!</p>
              </div>
            </div>
            <div class="group flex items-start gap-6">
              <span class="font-headline text-3xl text-secondary/40 group-hover:text-secondary transition-colors italic flex-shrink-0">02</span>
              <div>
                <h3 class="font-headline text-xl text-on-background mb-3">Where exactly is the event?</h3>
                <p class="text-on-surface-variant leading-relaxed font-body">Boise: Camel's Back Park. Salt Lake City: Sugar House Park. The full address and details will be sent to ticket holders via email once dates are confirmed.</p>
              </div>
            </div>
            <div class="group flex items-start gap-6">
              <span class="font-headline text-3xl text-secondary/40 group-hover:text-secondary transition-colors italic flex-shrink-0">03</span>
              <div>
                <h3 class="font-headline text-xl text-on-background mb-3">What if I have dietary restrictions?</h3>
                <p class="text-on-surface-variant leading-relaxed font-body">All flavors are celebrated! If you bring something with dietary restrictions in mind, let us know so we can label it accordingly for fellow guests.</p>
              </div>
            </div>
            <div class="group flex items-start gap-6">
              <span class="font-headline text-3xl text-secondary/40 group-hover:text-secondary transition-colors italic flex-shrink-0">04</span>
              <div>
                <h3 class="font-headline text-xl text-on-background mb-3">Can I come alone?</h3>
                <p class="text-on-surface-variant leading-relaxed font-body">Absolutely. Most of our guests arrive solo and leave having met a whole table of new friends. It's one of the best parts of the event!</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Signup + Ticket Section -->
      <section id="signup" class="py-24 bg-surface-container-high relative overflow-hidden">
        <div class="max-w-4xl mx-auto px-6 sm:px-8 text-center relative z-10">
          <h2 class="text-5xl font-headline mb-4 text-on-background">Will you join us?</h2>
          <p class="text-lg text-on-surface-variant mb-12 italic">Sign up to receive an invite, or purchase your ticket directly.</p>

          <!-- City Selection -->
          <div class="flex gap-3 justify-center mb-8">
            <label class="cursor-pointer">
              <input type="radio" name="city" value="boise" id="city-boise" class="peer sr-only" />
              <span class="block px-6 py-3 border border-outline-variant text-on-surface-variant text-sm font-label uppercase tracking-wider rounded-lg transition-colors peer-checked:bg-primary peer-checked:text-on-primary peer-checked:border-primary hover:bg-surface-container-highest">
                Boise, ID
              </span>
            </label>
            <label class="cursor-pointer">
              <input type="radio" name="city" value="slc" id="city-slc" class="peer sr-only" />
              <span class="block px-6 py-3 border border-outline-variant text-on-surface-variant text-sm font-label uppercase tracking-wider rounded-lg transition-colors peer-checked:bg-primary peer-checked:text-on-primary peer-checked:border-primary hover:bg-surface-container-highest">
                Salt Lake City, UT
              </span>
            </label>
          </div>

          <!-- Email signup form -->
          <form id="signup-form" class="grid grid-cols-1 md:grid-cols-2 gap-8 text-left max-w-2xl mx-auto mb-10">
            <div class="md:col-span-2 border-b border-outline-variant focus-within:border-primary transition-all pb-2">
              <label class="block text-xs uppercase tracking-widest text-on-surface-variant mb-2 font-label">Email Address</label>
              <input
                type="email"
                name="email"
                id="email-input"
                class="bg-transparent border-none w-full p-0 focus:ring-0 text-on-background placeholder:text-outline-variant font-body"
                placeholder="hello@example.com"
                required
              />
            </div>
            <div class="md:col-span-2 pt-4">
              <button
                type="submit"
                id="signup-button"
                class="w-full bg-primary text-on-primary py-4 rounded-lg font-headline text-lg hover:bg-primary-container hover:text-on-primary-container transition-all"
              >
                Sign Up for Invite
              </button>
            </div>
          </form>

          <!-- Success message (hidden by default) -->
          <div id="success-message" class="py-8 hidden">
            <p class="font-headline text-2xl text-primary mb-3">You're on the list!</p>
            <p class="text-on-surface-variant font-body">We'll email you an invite with all the event details once dates are confirmed.</p>
          </div>

          <!-- Divider -->
          <div class="flex items-center gap-4 max-w-2xl mx-auto my-8">
            <div class="flex-1 h-px bg-outline-variant"></div>
            <span class="text-on-surface-variant text-sm font-label uppercase tracking-widest">or</span>
            <div class="flex-1 h-px bg-outline-variant"></div>
          </div>

          <!-- Ticket purchase -->
