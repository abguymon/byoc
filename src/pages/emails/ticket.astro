---
import { ticketEmailHtml } from '../../emails/ticket';
if (import.meta.env.PROD) return new Response(null, { status: 404 });

const shared = {
  firstName: 'Jane',
  lastName: 'Smith',
  email: 'jane@example.com',
  code: 'TCKT-JANE2024',
  quantity: 2,
};
---
<html>
  <head>
    <meta charset="utf-8" />
    <title>Preview: Ticket Email</title>
    <style>
      body { margin: 0; background: #e5e5e5; padding: 40px 0; font-family: system-ui, sans-serif; }
      .variant-label { max-width: 600px; margin: 0 auto 12px; font-size: 11px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: #666; }
      .spacer { height: 48px; }
    </style>
  </head>
  <body>
    <div class="variant-label">Boise</div>
    <Fragment set:html={ticketEmailHtml({ ...shared, city: 'boise' })} />
    <div class="spacer"></div>
    <div class="variant-label">Salt Lake City</div>
    <Fragment set:html={ticketEmailHtml({ ...shared, city: 'slc' })} />
    <div class="spacer"></div>
    <div class="variant-label">Unknown city (null)</div>
    <Fragment set:html={ticketEmailHtml({ ...shared, city: null })} />
  </body>
</html>
