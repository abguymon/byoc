---
import { returningBoiseEmailHtml } from '../../emails/returning-boise';
if (import.meta.env.PROD) return new Response(null, { status: 404 });
---
<html>
  <head>
    <meta charset="utf-8" />
    <title>Preview: Returning Boise Email</title>
    <style>body { margin: 0; background: #e5e5e5; padding: 40px 0; }</style>
  </head>
  <body>
    <Fragment set:html={returningBoiseEmailHtml({
      checkoutUrlBoise: import.meta.env.STRIPE_CHECKOUT_URL_BOISE ?? '#',
      checkoutUrlSlc: import.meta.env.STRIPE_CHECKOUT_URL_SLC ?? '#',
    })} />
  </body>
</html>
