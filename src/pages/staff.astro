---
export const prerender = true;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Staff Portal | BYO Cake Club</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Serif:ital,wght@0,400;0,700;1,400;1,700&family=Work+Sans:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
      rel="stylesheet"
    />

    <style>
      .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
      }
    </style>
  </head>

  <body class="bg-background text-on-background font-body min-h-screen">

    <!-- Nav -->
    <nav class="bg-[#fef9ed]/80 backdrop-blur-xl sticky top-0 z-50 border-b border-outline-variant/20">
      <div class="flex justify-between items-center w-full px-6 sm:px-8 py-4 max-w-4xl mx-auto">
        <span class="text-xl font-headline italic text-primary">BRING YOUR OWN CAKE CLUB</span>
        <span class="font-label text-xs uppercase tracking-widest text-on-surface-variant">Staff Portal</span>
      </div>
    </nav>

    <main class="max-w-4xl mx-auto px-6 sm:px-8 py-12">

      <!-- Page header -->
      <div class="text-center mb-12">
        <span class="inline-block px-4 py-1 bg-secondary-container text-secondary text-xs font-label uppercase tracking-widest rounded-sm mb-6">
          Internal
        </span>
        <h1 class="font-headline text-4xl text-on-background mb-2">Staff Portal</h1>
        <p class="text-on-surface-variant font-body italic">Ticket Verification &amp; Check-in</p>
        <div class="w-16 h-px bg-secondary mx-auto mt-6"></div>
      </div>

      <!-- Auth Section -->
      <div id="auth-section" class="max-w-md mx-auto">
        <div class="bg-surface-container-lowest rounded-xl border border-outline-variant/20 shadow-sm p-8">
          <h2 class="font-headline text-xl text-on-background mb-8 text-center">Staff Login</h2>

          <form id="login-form" class="space-y-6">
            <div class="border-b border-outline-variant focus-within:border-primary transition-all pb-2">
              <label for="password" class="block text-xs uppercase tracking-widest text-on-surface-variant mb-2 font-label">
                Password
              </label>
              <input
                type="password"
                id="password"
                name="password"
                required
                class="bg-transparent border-none w-full p-0 focus:ring-0 text-on-background placeholder:text-outline-variant font-body"
                placeholder="Enter staff password"
              />
            </div>
            <button
              type="submit"
              id="login-button"
              class="w-full bg-primary text-on-primary py-4 rounded-lg font-headline text-lg hover:bg-primary-container hover:text-on-primary-container transition-all"
            >
              Login
            </button>
          </form>

          <p id="login-error" class="mt-4 text-error text-sm text-center hidden font-body">
            Invalid password. Please try again.
          </p>
        </div>
      </div>

      <!-- Staff Dashboard (hidden by default) -->
      <div id="staff-dashboard" class="hidden space-y-6">

        <!-- Scanner Card -->
        <div class="bg-surface-container-lowest rounded-xl border border-outline-variant/20 shadow-sm p-8">
          <h2 class="font-headline text-xl text-on-background mb-6 flex items-center gap-3">
            <span class="material-symbols-outlined text-primary">qr_code_scanner</span>
            QR Code Scanner
          </h2>

          <div class="text-center">
            <div id="scanner-container" class="mb-6">
              <video id="scanner-video" class="w-full max-w-md mx-auto rounded-xl hidden"></video>
              <canvas id="scanner-canvas" class="hidden"></canvas>
            </div>

            <div class="flex flex-wrap justify-center gap-3">
              <button
                id="start-scan-button"
                class="inline-flex items-center gap-2 bg-primary text-on-primary px-6 py-3 rounded-lg font-label text-sm uppercase tracking-wider hover:bg-primary-container hover:text-on-primary-container transition-all"
              >
                <span class="material-symbols-outlined text-base">videocam</span>
                Start Scanner
              </button>
              <button
                id="stop-scan-button"
                class="inline-flex items-center gap-2 bg-surface-container-highest text-on-surface px-6 py-3 rounded-lg font-label text-sm uppercase tracking-wider hover:bg-surface-container transition-all hidden"
              >
                <span class="material-symbols-outlined text-base">videocam_off</span>
                Stop Scanner
              </button>
            </div>

            <div id="manual-input" class="mt-8">
              <p class="text-on-surface-variant text-sm font-body mb-4 italic">Or enter ticket code manually:</p>
              <div class="flex gap-3 max-w-md mx-auto">
                <div class="flex-1 border-b border-outline-variant focus-within:border-primary transition-all pb-2">
                  <input
                    type="text"
                    id="manual-code-input"
                    placeholder="TCKT-ABC12345"
                    class="bg-transparent border-none w-full p-0 focus:ring-0 text-on-background placeholder:text-outline-variant font-body font-mono"
                  />
                </div>
                <button
                  id="verify-manual-button"
                  class="bg-surface-container-highest text-on-surface px-5 py-2 rounded-lg font-label text-sm uppercase tracking-wider hover:bg-primary hover:text-on-primary transition-all flex-shrink-0"
                >
                  Verify
                </button>
              </div>
            </div>
          </div>
        </div>

        <!-- Results Card (hidden until ticket scanned) -->
        <div id="results-section" class="bg-surface-container-lowest rounded-xl border border-outline-variant/20 shadow-sm p-8 hidden">
          <h2 class="font-headline text-xl text-on-background mb-6 flex items-center gap-3">
            <span class="material-symbols-outlined text-primary">confirmation_number</span>
            Ticket Details
          </h2>

          <div id="ticket-info" class="space-y-4"></div>

          <div class="mt-8 flex flex-wrap gap-3 justify-center">
            <button
              id="redeem-button"
              class="inline-flex items-center gap-2 bg-primary text-on-primary px-6 py-3 rounded-lg font-label text-sm uppercase tracking-wider hover:bg-primary-container hover:text-on-primary-container transition-all"
            >
              <span class="material-symbols-outlined text-base">check_circle</span>
              Mark as Redeemed
            </button>
            <button
              id="scan-another-button"
              class="inline-flex items-center gap-2 bg-surface-container-highest text-on-surface px-6 py-3 rounded-lg font-label text-sm uppercase tracking-wider hover:bg-surface-container transition-all"
            >
              <span class="material-symbols-outlined text-base">refresh</span>
              Scan Another
            </button>
          </div>
        </div>

        <!-- Logout -->
        <div class="text-center pt-4">
          <button
            id="logout-button"
            class="inline-flex items-center gap-2 text-on-surface-variant font-label text-sm uppercase tracking-widest hover:text-secondary transition-colors"
          >
            <span class="material-symbols-outlined text-base">logout</span>
            Logout
          </button>
        </div>
      </div>

    </main>

    <!-- Footer -->
    <footer class="bg-surface border-t border-outline-variant/20 mt-16">
      <div class="max-w-4xl mx-auto px-8 py-8 text-center">
        <p class="text-on-surface-variant text-sm font-body">© 2026 BYO Cake Club — Staff use only</p>
      </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/jsqr@1.4.0/dist/jsQR.js"></script>

    <script>
      let video: HTMLVideoElement | null = null;
      let canvas: HTMLCanvasElement | null = null;
      let context: CanvasRenderingContext2D | null = null;
      let scanning = false;
      let currentTicket: any = null;
      let isAuthenticated = false;

      const authSection = document.getElementById('auth-section') as HTMLElement | null;
      const staffDashboard = document.getElementById('staff-dashboard') as HTMLElement | null;
      const loginForm = document.getElementById('login-form') as HTMLFormElement | null;
      const loginError = document.getElementById('login-error') as HTMLElement | null;
      const logoutButton = document.getElementById('logout-button') as HTMLButtonElement | null;
      const scannerVideo = document.getElementById('scanner-video') as HTMLVideoElement | null;
      const scannerCanvas = document.getElementById('scanner-canvas') as HTMLCanvasElement | null;
      const startScanButton = document.getElementById('start-scan-button') as HTMLButtonElement | null;
      const stopScanButton = document.getElementById('stop-scan-button') as HTMLButtonElement | null;
      const manualCodeInput = document.getElementById('manual-code-input') as HTMLInputElement | null;
      const verifyManualButton = document.getElementById('verify-manual-button') as HTMLButtonElement | null;
      const resultsSection = document.getElementById('results-section') as HTMLElement | null;
      const ticketInfo = document.getElementById('ticket-info') as HTMLElement | null;
      const redeemButton = document.getElementById('redeem-button') as HTMLButtonElement | null;
      const scanAnotherButton = document.getElementById('scan-another-button') as HTMLButtonElement | null;

      async function checkAuthStatus() {
        try {
          const response = await fetch('/api/verify-session');
          const result = await response.json();
          if (result.authenticated) {
            isAuthenticated = true;
            authSection?.classList.add('hidden');
            staffDashboard?.classList.remove('hidden');
          }
        } catch {}
      }

      loginForm?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const passwordInput = document.getElementById('password') as HTMLInputElement;
        const password = passwordInput?.value || '';
        try {
          const response = await fetch('/api/staff-auth', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ password }),
          });
          const result = await response.json();
          if (response.ok && result.success) {
            isAuthenticated = true;
            authSection?.classList.add('hidden');
            staffDashboard?.classList.remove('hidden');
            loginError?.classList.add('hidden');
            if (passwordInput) passwordInput.value = '';
          } else {
            loginError?.classList.remove('hidden');
            if (passwordInput) passwordInput.value = '';
          }
        } catch {
          loginError?.classList.remove('hidden');
        }
      });

      logoutButton?.addEventListener('click', async () => {
        stopScanning();
        try {
          await fetch('/api/staff-auth', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ logout: true }),
          });
        } catch {}
        isAuthenticated = false;
        authSection?.classList.remove('hidden');
        staffDashboard?.classList.add('hidden');
        resultsSection?.classList.add('hidden');
        const passwordInput = document.getElementById('password') as HTMLInputElement;
        if (passwordInput) passwordInput.value = '';
        currentTicket = null;
      });

      startScanButton?.addEventListener('click', startScanning);
      stopScanButton?.addEventListener('click', stopScanning);

      verifyManualButton?.addEventListener('click', () => {
        const code = manualCodeInput?.value?.trim() || '';
        if (code) verifyTicket(code);
      });

      manualCodeInput?.addEventListener('keypress', (e) => {
        if (e.key === 'Enter') verifyManualButton?.click();
      });

      redeemButton?.addEventListener('click', async () => {
        if (currentTicket) await redeemTicket(currentTicket.code);
      });

      scanAnotherButton?.addEventListener('click', () => {
        resultsSection?.classList.add('hidden');
        currentTicket = null;
        if (manualCodeInput) manualCodeInput.value = '';
      });

      async function startScanning() {
        try {
          if (!scannerVideo || !scannerCanvas) throw new Error('Scanner elements not found');
          video = scannerVideo;
          canvas = scannerCanvas;
          context = canvas.getContext('2d');
          if (!context) throw new Error('Could not get canvas context');
          const stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment' } });
          video.srcObject = stream;
          video.play();
          video.classList.remove('hidden');
          startScanButton?.classList.add('hidden');
          stopScanButton?.classList.remove('hidden');
          scanning = true;
          scanForQRCode();
        } catch {
          alert('Unable to access camera. Please check permissions.');
        }
      }

      function stopScanning() {
        scanning = false;
        if (video && video.srcObject) {
          const stream = video.srcObject as MediaStream;
          stream.getTracks().forEach((track: MediaStreamTrack) => track.stop());
          video.srcObject = null;
        }
        video?.classList.add('hidden');
        startScanButton?.classList.remove('hidden');
        stopScanButton?.classList.add('hidden');
      }

      function scanForQRCode() {
        if (!scanning || !video || !canvas || !context) return;
        if (video.readyState === video.HAVE_ENOUGH_DATA) {
          canvas.height = video.videoHeight;
          canvas.width = video.videoWidth;
          context.drawImage(video, 0, 0, canvas.width, canvas.height);
          const imageData = context.getImageData(0, 0, canvas.width, canvas.height);
          // @ts-ignore
          const code = jsQR(imageData.data, imageData.width, imageData.height);
          if (code) {
            stopScanning();
            verifyTicket(code.data);
            return;
          }
        }
        requestAnimationFrame(scanForQRCode);
      }

      async function verifyTicket(code: string) {
        try {
          const response = await fetch('/api/verify-ticket', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ code }),
          });
          const result = await response.json();
          if (response.ok) {
            currentTicket = result.ticket;
            displayTicketInfo(result.ticket);
            resultsSection?.classList.remove('hidden');
          } else {
            alert(`Error: ${result.error}`);
          }
        } catch {
          alert('Error verifying ticket. Please try again.');
        }
      }

      function displayTicketInfo(ticket: any) {
        if (!ticketInfo) return;
        const isRedeemed = !!ticket.redeemed_at;
        const statusColor = isRedeemed ? 'text-error' : 'text-primary';
        const statusText = isRedeemed ? 'Already Redeemed' : 'Valid — Not Yet Redeemed';
        const statusIcon = isRedeemed ? 'cancel' : 'check_circle';
        const redeemedDate = ticket.redeemed_at ? new Date(ticket.redeemed_at).toLocaleString() : '—';

        ticketInfo.innerHTML = `
          <div class="bg-surface-container-low rounded-xl p-6">
            <div class="flex items-center gap-3 mb-6">
              <span class="material-symbols-outlined ${statusColor} text-3xl">${statusIcon}</span>
              <div>
                <p class="font-label text-xs uppercase tracking-widest text-on-surface-variant">Status</p>
                <p class="${statusColor} font-headline text-xl">${statusText}</p>
              </div>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <p class="font-label text-xs uppercase tracking-widest text-on-surface-variant mb-1">Ticket Code</p>
                <p class="text-on-background font-mono font-semibold">${ticket.code}</p>
              </div>
              <div>
                <p class="font-label text-xs uppercase tracking-widest text-on-surface-variant mb-1">Name</p>
                <p class="text-on-background font-body">${ticket.first_name || '—'} ${ticket.last_name || ''}</p>
              </div>
              <div>
                <p class="font-label text-xs uppercase tracking-widest text-on-surface-variant mb-1">Email</p>
                <p class="text-on-background font-body">${ticket.email || '—'}</p>
              </div>
              <div>
                <p class="font-label text-xs uppercase tracking-widest text-on-surface-variant mb-1">Quantity</p>
                <p class="text-on-background font-body">${ticket.quantity || 1}</p>
              </div>
              <div>
                <p class="font-label text-xs uppercase tracking-widest text-on-surface-variant mb-1">Purchased</p>
                <p class="text-on-background font-body">${new Date(ticket.issued_at).toLocaleString()}</p>
              </div>
              <div>
                <p class="font-label text-xs uppercase tracking-widest text-on-surface-variant mb-1">Redeemed At</p>
                <p class="text-on-background font-body">${redeemedDate}</p>
              </div>
            </div>
          </div>
        `;

        if (isRedeemed) {
          redeemButton?.classList.add('hidden');
        } else {
          redeemButton?.classList.remove('hidden');
        }
      }

      async function redeemTicket(code: string) {
        try {
          const response = await fetch('/api/redeem-ticket', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ code }),
          });
          const result = await response.json();
          if (response.ok) {
            await verifyTicket(code);
          } else {
            alert(`Error: ${result.error}`);
          }
        } catch {
          alert('Error redeeming ticket. Please try again.');
        }
      }

      document.addEventListener('DOMContentLoaded', checkAuthStatus);
    </script>
  </body>
</html>
