---
// Password-protected staff page for QR code scanning
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Staff Portal - BYO Cake Club</title>
    
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Great+Vibes&family=Inter:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-byoc-teal min-h-screen">
    <div class="max-w-4xl mx-auto px-4 py-8">
      <!-- Header -->
      <div class="text-center mb-8">
        <h1 class="text-byoc-pink text-3xl font-serif font-bold mb-2">
          Staff Portal
        </h1>
        <p class="text-byoc-text-pink text-lg font-sans">
          BYO Cake Club - Ticket Verification
        </p>
      </div>

      <!-- Authentication Section -->
      <div id="auth-section" class="max-w-md mx-auto">
        <div class="bg-white rounded-lg shadow-lg p-8">
          <h2 class="text-byoc-pink text-xl font-sans font-semibold mb-6 text-center">
            Staff Login
          </h2>
          
          <form id="login-form" class="space-y-4">
            <div>
              <label for="password" class="block text-sm font-medium text-gray-700 mb-2">
                Password
              </label>
              <input
                type="password"
                id="password"
                name="password"
                required
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-byoc-pink focus:border-transparent"
                placeholder="Enter staff password"
              />
            </div>
            
            <button
              type="submit"
              id="login-button"
              class="w-full bg-byoc-pink text-white py-3 px-4 rounded-lg font-sans font-semibold hover:bg-opacity-90 transition-colors"
            >
              Login
            </button>
          </form>
          
          <div id="login-error" class="mt-4 text-red-600 text-sm text-center hidden">
            Invalid password. Please try again.
          </div>
        </div>
      </div>

      <!-- Staff Dashboard (Hidden by default) -->
      <div id="staff-dashboard" class="hidden">
        <!-- Scanner Section -->
        <div class="bg-white rounded-lg shadow-lg p-6 mb-6">
          <h2 class="text-byoc-pink text-xl font-sans font-semibold mb-4">
            QR Code Scanner
          </h2>
          
          <div class="text-center">
            <div id="scanner-container" class="mb-4">
              <video id="scanner-video" class="w-full max-w-md mx-auto rounded-lg hidden"></video>
              <canvas id="scanner-canvas" class="hidden"></canvas>
            </div>
            
            <button
              id="start-scan-button"
              class="bg-byoc-pink text-white px-6 py-3 rounded-lg font-sans font-semibold hover:bg-opacity-90 transition-colors mr-4"
            >
              Start Scanner
            </button>
            
            <button
              id="stop-scan-button"
              class="bg-gray-500 text-white px-6 py-3 rounded-lg font-sans font-semibold hover:bg-opacity-90 transition-colors hidden"
            >
              Stop Scanner
            </button>
            
            <div id="manual-input" class="mt-4">
              <p class="text-gray-600 text-sm mb-2">Or enter ticket code manually:</p>
              <div class="flex gap-2 max-w-md mx-auto">
                <input
                  type="text"
                  id="manual-code-input"
                  placeholder="TCKT-ABC12345"
                  class="flex-1 px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-byoc-pink"
                />
                <button
                  id="verify-manual-button"
                  class="bg-blue-500 text-white px-4 py-2 rounded-lg font-sans font-semibold hover:bg-opacity-90 transition-colors"
                >
                  Verify
                </button>
              </div>
            </div>
          </div>
        </div>

        <!-- Results Section -->
        <div id="results-section" class="bg-white rounded-lg shadow-lg p-6 hidden">
          <h2 class="text-byoc-pink text-xl font-sans font-semibold mb-4">
            Ticket Verification Results
          </h2>
          
          <div id="ticket-info" class="space-y-4">
            <!-- Ticket details will be populated here -->
          </div>
          
          <div class="mt-6 flex gap-4 justify-center">
            <button
              id="redeem-button"
              class="bg-green-500 text-white px-6 py-3 rounded-lg font-sans font-semibold hover:bg-opacity-90 transition-colors"
            >
              Mark as Redeemed
            </button>
            
            <button
              id="scan-another-button"
              class="bg-gray-500 text-white px-6 py-3 rounded-lg font-sans font-semibold hover:bg-opacity-90 transition-colors"
            >
              Scan Another
            </button>
          </div>
        </div>

        <!-- Logout Section -->
        <div class="text-center mt-8">
          <button
            id="logout-button"
            class="text-byoc-text-pink hover:text-byoc-pink transition-colors font-sans"
          >
            Logout
          </button>
        </div>
      </div>
    </div>

    <!-- Include QR Code Scanner Library -->
    <script src="https://cdn.jsdelivr.net/npm/jsqr@1.4.0/dist/jsQR.js"></script>

    <script>
      // Global variables
      let video: HTMLVideoElement | null = null;
      let canvas: HTMLCanvasElement | null = null;
      let context: CanvasRenderingContext2D | null = null;
      let scanning = false;
      let currentTicket: any = null;
      let isAuthenticated = false;

      // DOM elements
      const authSection = document.getElementById('auth-section') as HTMLElement | null;
      const staffDashboard = document.getElementById('staff-dashboard') as HTMLElement | null;
      const loginForm = document.getElementById('login-form') as HTMLFormElement | null;
      const loginError = document.getElementById('login-error') as HTMLElement | null;
      const loginButton = document.getElementById('login-button') as HTMLButtonElement | null;
      const logoutButton = document.getElementById('logout-button') as HTMLButtonElement | null;
      
      const scannerContainer = document.getElementById('scanner-container') as HTMLElement | null;
      const scannerVideo = document.getElementById('scanner-video') as HTMLVideoElement | null;
      const scannerCanvas = document.getElementById('scanner-canvas') as HTMLCanvasElement | null;
      const startScanButton = document.getElementById('start-scan-button') as HTMLButtonElement | null;
      const stopScanButton = document.getElementById('stop-scan-button') as HTMLButtonElement | null;
      const manualCodeInput = document.getElementById('manual-code-input') as HTMLInputElement | null;
      const verifyManualButton = document.getElementById('verify-manual-button') as HTMLButtonElement | null;
      
      const resultsSection = document.getElementById('results-section') as HTMLElement | null;
      const ticketInfo = document.getElementById('ticket-info') as HTMLElement | null;
      const redeemButton = document.getElementById('redeem-button') as HTMLButtonElement | null;
      const scanAnotherButton = document.getElementById('scan-another-button') as HTMLButtonElement | null;

      // Check authentication status on page load
      async function checkAuthStatus() {
        try {
          const response = await fetch('/api/verify-session');
          const result = await response.json();
          
          if (result.authenticated) {
            isAuthenticated = true;
            authSection?.classList.add('hidden');
            staffDashboard?.classList.remove('hidden');
          } else {
            isAuthenticated = false;
            authSection?.classList.remove('hidden');
            staffDashboard?.classList.add('hidden');
          }
        } catch (error) {
          console.error('Error checking auth status:', error);
          isAuthenticated = false;
        }
      }

      // Authentication
      loginForm?.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const passwordInput = document.getElementById('password') as HTMLInputElement;
        const password = passwordInput?.value || '';
        
        try {
          const response = await fetch('/api/staff-auth', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({ password }),
          });

          const result = await response.json();

          if (response.ok && result.success) {
            // Successful login
            isAuthenticated = true;
            authSection?.classList.add('hidden');
            staffDashboard?.classList.remove('hidden');
            loginError?.classList.add('hidden');
            if (passwordInput) passwordInput.value = '';
          } else {
            // Failed login
            loginError?.classList.remove('hidden');
            if (passwordInput) passwordInput.value = '';
          }
        } catch (error) {
          console.error('Authentication error:', error);
          loginError?.classList.remove('hidden');
          if (passwordInput) passwordInput.value = '';
        }
      });

      // Logout
      logoutButton?.addEventListener('click', async () => {
        stopScanning();
        
        // Clear session cookie
        try {
          await fetch('/api/staff-auth', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({ logout: true }),
          });
        } catch (error) {
          console.error('Logout error:', error);
        }
        
        isAuthenticated = false;
        authSection?.classList.remove('hidden');
        staffDashboard?.classList.add('hidden');
        resultsSection?.classList.add('hidden');
        const passwordInput = document.getElementById('password') as HTMLInputElement;
        if (passwordInput) passwordInput.value = '';
        currentTicket = null;
      });

      // Start scanning
      startScanButton?.addEventListener('click', startScanning);
      stopScanButton?.addEventListener('click', stopScanning);

      // Manual verification
      verifyManualButton?.addEventListener('click', () => {
        const code = manualCodeInput?.value?.trim() || '';
        if (code) {
          verifyTicket(code);
        }
      });

      // Manual input enter key
      manualCodeInput?.addEventListener('keypress', (e) => {
        if (e.key === 'Enter') {
          verifyManualButton?.click();
        }
      });

      // Redeem ticket
      redeemButton?.addEventListener('click', async () => {
        if (currentTicket) {
          await redeemTicket(currentTicket.code);
        }
      });

      // Scan another
      scanAnotherButton?.addEventListener('click', () => {
        resultsSection?.classList.add('hidden');
        currentTicket = null;
        if (manualCodeInput) manualCodeInput.value = '';
      });

      async function startScanning() {
        try {
          if (!scannerVideo || !scannerCanvas) {
            throw new Error('Scanner elements not found');
          }
          
          video = scannerVideo;
          canvas = scannerCanvas;
          context = canvas.getContext('2d');

          if (!context) {
            throw new Error('Could not get canvas context');
          }

          const stream = await navigator.mediaDevices.getUserMedia({
            video: { facingMode: 'environment' }
          });

          video.srcObject = stream;
          video.play();

          video.classList.remove('hidden');
          startScanButton?.classList.add('hidden');
          stopScanButton?.classList.remove('hidden');

          scanning = true;
          scanForQRCode();
        } catch (error) {
          console.error('Error accessing camera:', error);
          alert('Unable to access camera. Please check permissions.');
        }
      }

      function stopScanning() {
        scanning = false;
        
        if (video && video.srcObject) {
          const stream = video.srcObject as MediaStream;
          const tracks = stream.getTracks();
          tracks.forEach((track: MediaStreamTrack) => track.stop());
          video.srcObject = null;
        }

        video?.classList.add('hidden');
        startScanButton?.classList.remove('hidden');
        stopScanButton?.classList.add('hidden');
      }

      function scanForQRCode() {
        if (!scanning || !video || !canvas || !context) return;

        if (video.readyState === video.HAVE_ENOUGH_DATA) {
          canvas.height = video.videoHeight;
          canvas.width = video.videoWidth;
          context.drawImage(video, 0, 0, canvas.width, canvas.height);

          const imageData = context.getImageData(0, 0, canvas.width, canvas.height);
          // @ts-ignore - jsQR is loaded from CDN
          const code = jsQR(imageData.data, imageData.width, imageData.height);

          if (code) {
            console.log('QR Code detected:', code.data);
            stopScanning();
            verifyTicket(code.data);
          }
        }

        requestAnimationFrame(scanForQRCode);
      }

      async function verifyTicket(code: string) {
        try {
          const response = await fetch('/api/verify-ticket', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({ code }),
          });

          const result = await response.json();

          if (response.ok) {
            currentTicket = result.ticket;
            displayTicketInfo(result.ticket);
            resultsSection?.classList.remove('hidden');
          } else {
            alert(`Error: ${result.error}`);
          }
        } catch (error) {
          console.error('Error verifying ticket:', error);
          alert('Error verifying ticket. Please try again.');
        }
      }

      function displayTicketInfo(ticket: any) {
        if (!ticketInfo) return;
        
        const statusClass = ticket.redeemed_at ? 'text-red-600' : 'text-green-600';
        const statusText = ticket.redeemed_at ? 'Already Redeemed' : 'Valid - Not Redeemed';
        const redeemedDate = ticket.redeemed_at ? new Date(ticket.redeemed_at).toLocaleString() : 'N/A';

        ticketInfo.innerHTML = `
          <div class="bg-gray-50 rounded-lg p-4">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <h3 class="font-semibold text-gray-700">Ticket Code</h3>
                <p class="text-lg font-mono">${ticket.code}</p>
              </div>
              
              <div>
                <h3 class="font-semibold text-gray-700">Status</h3>
                <p class="${statusClass} font-semibold">${statusText}</p>
              </div>
              
              <div>
                <h3 class="font-semibold text-gray-700">Customer Name</h3>
                <p>${ticket.first_name || 'N/A'} ${ticket.last_name || ''}</p>
              </div>
              
              <div>
                <h3 class="font-semibold text-gray-700">Email</h3>
                <p>${ticket.email || 'N/A'}</p>
              </div>
              
              <div>
                <h3 class="font-semibold text-gray-700">Quantity</h3>
                <p>${ticket.quantity || 1}</p>
              </div>
              
              <div>
                <h3 class="font-semibold text-gray-700">Redeemed Date</h3>
                <p>${redeemedDate}</p>
              </div>
              
              <div>
                <h3 class="font-semibold text-gray-700">Purchase Date</h3>
                <p>${new Date(ticket.created_at).toLocaleString()}</p>
              </div>
            </div>
          </div>
        `;

        // Show/hide redeem button based on status
        if (ticket.redeemed_at) {
          redeemButton?.classList.add('hidden');
        } else {
          redeemButton?.classList.remove('hidden');
        }
      }

      async function redeemTicket(code: string) {
        try {
          const response = await fetch('/api/redeem-ticket', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({ code }),
          });

          const result = await response.json();

          if (response.ok) {
            alert('Ticket successfully redeemed!');
            // Refresh the ticket info
            await verifyTicket(code);
          } else {
            alert(`Error: ${result.error}`);
          }
        } catch (error) {
          console.error('Error redeeming ticket:', error);
          alert('Error redeeming ticket. Please try again.');
        }
      }

      // Initialize authentication check when page loads
      document.addEventListener('DOMContentLoaded', checkAuthStatus);
    </script>
  </body>
</html>
