# BYOC (Bring Your Own Cake) Environment Variables
# Copy this file to .env and update with your actual values

# Email Service (Resend)
RESEND_API_KEY=re_your_api_key_here
MAIL_FROM=BYO Cake Club <noreply@bringyourowncake.com>

# Staff Portal Password (choose a secure password)
STAFF_PASSWORD=change_this_to_a_secure_password_123

# Supabase Database (if using database features)
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Stripe Payment Processing (if using payments)
STRIPE_SECRET_KEY=sk_test_your_stripe_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
